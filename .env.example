# =============================================================================
# Bubble Buddies - Environment Variables
# =============================================================================
# Copy to .env.local for local dev, or set in Vercel/hosting for production.
# Never commit .env.local or .env.production to git.
# =============================================================================

# -----------------------------------------------------------------------------
# LOCAL DEVELOPMENT (use with `supabase start`)
# -----------------------------------------------------------------------------
# Get these from: supabase status (after running supabase start)
#
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54331
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key-from-supabase-status>

# -----------------------------------------------------------------------------
# PRODUCTION (Supabase Cloud)
# -----------------------------------------------------------------------------
# Get these from: Supabase Dashboard → Project Settings → API
#
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key-from-dashboard>

# Resend (welcome email)
# RESEND_API_KEY=re_xxxx
# RESEND_FROM_EMAIL=The Bubble Heroes <noreply@thebubbleheros.com>
# NEXT_PUBLIC_SITE_URL=https://thebubbleheros.com
